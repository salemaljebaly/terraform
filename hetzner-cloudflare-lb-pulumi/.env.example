# Hetzner Cloud API token
# Create at: console.hetzner.com → Security → API Tokens (Read & Write)
HCLOUD_TOKEN=your_hetzner_api_token_here

# Cloudflare API token
# Create at: dash.cloudflare.com → My Profile → API Tokens
# Required permissions: Zone → DNS (Edit)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Cloudflare Zone ID
# Find at: dash.cloudflare.com → your domain → Overview (right sidebar)
CLOUDFLARE_ZONE_ID=your_zone_id_here

# Your domain (must be added to Cloudflare)
DOMAIN=example.com

# Cloudflare Origin Certificate and private key
# Generate at: dash.cloudflare.com → your domain → SSL/TLS → Origin Server → Create Certificate
TLS_CERT=your_origin_certificate_here
TLS_PRIVATE_KEY=your_private_key_here

# Pulumi passphrase — used to encrypt/decrypt secrets in local state
# Choose any strong passphrase and keep it safe
PULUMI_CONFIG_PASSPHRASE=your_passphrase_here
